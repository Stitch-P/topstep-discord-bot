        "@microsoft/signalr": "^10.0.0",
        "axios": "^1.9.0",
        "cacheable-lookup": "^7.0.0",
        "canvas": "^3.2.1",
        "chalk": "^5.4.1",
        "cheerio": "^1.1.2",
        "csv-parse": "^6.1.0",
        "dayjs": "^1.11.13",
        "discord.js": "^14.21.0",
        "dotenv": "^16.3.1",
        "googleapis": "^131.0.0",
